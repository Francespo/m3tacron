# Performance Suite Environment Configuration
# Copy to .env and fill in values. NEVER commit .env.

# PostgreSQL for local performance stack
LOCAL_DB_HOST=postgres
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=m3tacron_perf
LOCAL_DB_USER=perf_user
LOCAL_DB_PASSWORD=perf_password

# DATABASE_URL is intentionally not provided by default.
# The backend composes it from LOCAL_DB_* component variables.

# Frontend configuration
VITE_API_BASE=http://localhost:8888/api
VITE_PROXY_TARGET=http://backend:8888
VITE_ALLOWED_HOSTS=localhost
ORIGIN=http://localhost:3333

# Dev DB refresh (SSH to real server)
# PERF_SSH_HOST=your-server-ip
# PERF_SSH_USER=your-ssh-user
# PERF_SSH_KEY_PATH=~/.ssh/id_ed25519
# PERF_DB_CONTAINER=m3tacron-dev-db
# PERF_DB_NAME=m3tacron_dev
# PERF_DB_USER=postgres

# k6 load test target
TARGET_URL=http://localhost:8888

# Lighthouse target
LIGHTHOUSE_URL=http://localhost:3333

# Performance thresholds (override defaults)
# K6_P95_THRESHOLD=1000
# K6_P99_THRESHOLD=3000
# K6_ERROR_RATE_THRESHOLD=0.01
# LIGHTHOUSE_PERF_THRESHOLD=0.8
